generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./bustravel.db"
}

model ContactMessage {
  id        String   @id @default(uuid())
  nom       String
  email     String
  sujet     String?
  message   String
  lu        Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}
